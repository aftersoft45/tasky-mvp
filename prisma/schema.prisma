generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// Sprints (Iteraciones de trabajo)    //Luis 21
model Sprint {
  id           String     @id @default(cuid())
  name         String     
  goal         String?    @db.Text 
  startDate    DateTime?
  endDate      DateTime?
  status       String     @default("PLANNED") 
  
  taskyspaceId String
  taskyspace   Taskyspace @relation(fields: [taskyspaceId], references: [id], onDelete: Cascade)

  tasks        Task[]
 

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Épicas (Grandes iniciativas que agrupan tareas)     //Luis 21
model Epic {
  id           String     @id @default(cuid())
  name         String     
  color        String     @default("bg-purple-500") 
  description  String?    @db.Text 
  taskyspaceId String
  taskyspace   Taskyspace @relation(fields: [taskyspaceId], references: [id], onDelete: Cascade)

  tasks        Task[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// TABLAS DE NEXTAUTH 
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// MODELO DE USUARIO 
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  
  // Relaciones para Tasky
  ownedSpaces         Taskyspace[] @relation("SpaceOwner")
  memberships         Member[]
  sentInvitations     Invitation[] @relation("SentInvitations") 
  receivedInvitations Invitation[] @relation("ReceivedInvitations") 
  
  // Tareas relacionadas
  assignedTasks       Task[]       @relation("TaskAssignee") 
  tasksSupported      Task[]       @relation("TaskSupport")  
  tasksAuthored       Task[]       @relation("TaskAuthor")   

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// MODELOS DE TASKY        //luis 21

model Taskyspace {
  id          String    @id @default(cuid())
  name        String
  privacy     String    
  password    String?   
  
  ownerId     String
  owner       User      @relation("SpaceOwner", fields: [ownerId], references: [id])

  members     Member[]
  invitations Invitation[] 
  columns     Column[]      
  activities  ActivityType[]
  tasks       Task[]
  sprints     Sprint[]   
  epics       Epic[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Miembros de un equipo     //Luis 21
model Member {
  id           String     @id @default(cuid())
  role         String     
  
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  taskyspaceId String
  taskyspace   Taskyspace @relation(fields: [taskyspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, taskyspaceId])
}

// Columnas del Kanban      //Luis 21
model Column {
  id           String     @id @default(cuid())
  title        String     
  color        String?    @default("#10b981")
  order        Int        @default(0)
  
  taskyspaceId String
  taskyspace   Taskyspace @relation(fields: [taskyspaceId], references: [id], onDelete: Cascade)
  
  tasks        Task[]
}

// Tipos de actividades (Ej: Tarea, Historia, Error)      //Luis 21
model ActivityType {
  id           String     @id @default(cuid())
  name         String
  
  taskyspaceId String
  taskyspace   Taskyspace @relation(fields: [taskyspaceId], references: [id], onDelete: Cascade)
  
  tasks        Task[]
}

// Tareas individuales (Las tarjetas)       //Luis 21
model Task {
  id                 String        @id @default(cuid()) 
  title              String
  description        String?       @db.Text 
  order              Int           @default(0) 
  isCompleted        Boolean       @default(false)
  
//NUEVOS CAMPOS DEL EXCEL (BACKLOG SPRINT) 
  type               String?       @default("Task") 
  priority           String?       @default("Media") 
  effortHours        Float?        @default(0)       
  dueDate            DateTime?     
  isBlocked          Boolean       @default(false)   
  dependencies       String?                         
  acceptanceCriteria String?       @db.Text          
  prLink             String?                         
  notes              String?       @db.Text          
  closedAt           DateTime?                       
  
  //RELACIÓN DE SUB-TAREAS 
  parentId           String?
  parent             Task?      @relation("TaskToSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks           Task[]     @relation("TaskToSubtasks")

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // RELACIONES 
  sprintId           String?
  sprint             Sprint?       @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  epicId      String?
  epic        Epic?      @relation(fields: [epicId], references: [id], onDelete: SetNull)

  taskyspaceId       String
  taskyspace         Taskyspace    @relation(fields: [taskyspaceId], references: [id], onDelete: Cascade)

  columnId           String        
  column             Column        @relation(fields: [columnId], references: [id], onDelete: Cascade)

  activityTypeId     String?
  activityType       ActivityType? @relation(fields: [activityTypeId], references: [id])

  assigneeId         String?       
  assignee           User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  supportId          String?
  support            User?         @relation("TaskSupport", fields: [supportId], references: [id], onDelete: SetNull)

  authorId           String?
  author             User?         @relation("TaskAuthor", fields: [authorId], references: [id], onDelete: SetNull)
}

// SISTEMA DE INVITACIONES
model Invitation {
  id             String     @id @default(cuid())
  role           String     
  status         String     @default("PENDIENTE") 
  
  taskyspaceId   String
  taskyspace     Taskyspace @relation(fields: [taskyspaceId], references: [id], onDelete: Cascade)
  
  inviterId      String
  inviter        User       @relation("SentInvitations", fields: [inviterId], references: [id])
  
  invitedUserId  String
  invitedUser    User       @relation("ReceivedInvitations", fields: [invitedUserId], references: [id])
  
  createdAt      DateTime   @default(now())
}